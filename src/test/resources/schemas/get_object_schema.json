{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generic Object Schema",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "data": {
      "type": ["object", "null"],
      "additionalProperties": {
        "type": ["string", "number", "integer", "boolean", "null"]
      }
    }
  },
  "required": ["id", "name"]
}
