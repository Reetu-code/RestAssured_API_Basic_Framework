<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="RestAssured_Basic" parallel="classes" thread-count="3">

    <parameter name="baseURL" value="${baseURL}"/>
    <parameter name="env" value="${env}"/>

    parallel="classes" thread-count="3"


    <listeners>
        <listener class-name="reports.ExtentListener"/>
    </listeners>

    <test name="CRUD API Tests">
        <classes>
            <class name="test.Test_GET"/>
            <class name="Test_DELETE"/>
            <class name="Test_PATCH"/>
            <class name="test.Test_POST"/>
            <class name="test.Test_PUT"/>
        </classes>
    </test>

</suite>
